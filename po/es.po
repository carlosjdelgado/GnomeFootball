#: prefs.js:168
msgid "Catalog"
msgstr "Catálogo"

#: prefs.js:169
msgid ""
"Leagues and teams are loaded from a public sports data source and cached "
"locally."
msgstr ""
"Las ligas y equipos se cargan desde una fuente pública de datos deportivos y "
"se guardan en caché local."

#: prefs.js:178
msgid "Refresh now"
msgstr "Actualizar ahora"

#: prefs.js:235 prefs.js:251 prefs.js:340
msgid "Off"
msgstr "Desactivado"

#: prefs.js:252
msgid "enabled"
msgstr "activadas"

#: prefs.js:292
msgid "Specific teams only"
msgstr "Solo equipos seleccionados"

#: prefs.js:293
msgid "Notify only for matches involving selected teams"
msgstr "Notificar solo los partidos en los que jueguen equipos seleccionados"

#: prefs.js:299 prefs.js:388
msgid "Teams will appear once the catalog has loaded."
msgstr "Los equipos aparecerán cuando se cargue el catálogo."

#: prefs.js:343
msgid "All matches"
msgstr "Todos los partidos"

#: prefs.js:347
msgid "1 team selected"
msgstr "1 equipo seleccionado"

#: prefs.js:348
msgid "teams selected"
msgstr "equipos seleccionados"

#: prefs.js:427
msgid "Events"
msgstr "Eventos"

#: prefs.js:436
msgid "Match reminder"
msgstr "Recordatorio de partido"

#: prefs.js:437
msgid "Get a heads-up before a subscribed match kicks off."
msgstr "Recibe un aviso antes de que empiece un partido suscrito."

#: prefs.js:442
msgid "Remind me before kick-off"
msgstr "Avisarme antes del inicio"

#: prefs.js:456
msgid "Minutes before kick-off"
msgstr "Minutos antes del inicio"

#: prefs.js:457
msgid "Range: 5-180 minutes"
msgstr "Rango: 5-180 minutos"

#: prefs.js:468
msgid "Notification types"
msgstr "Tipos de notificación"

#: prefs.js:469
msgid "Choose which match events trigger a notification."
msgstr "Elige qué eventos del partido disparan una notificación."

#: prefs.js:488
msgid "General"
msgstr "General"

#: prefs.js:494
msgid "Polling"
msgstr "Sondeo"

#: prefs.js:495
msgid ""
"How often to check for match updates. Lower values catch events sooner but "
"use more bandwidth."
msgstr ""
"Cada cuánto consultar actualizaciones de los partidos. Valores menores "
"detectan eventos antes pero usan más ancho de banda."

#: prefs.js:507
msgid "Polling interval (minutes)"
msgstr "Intervalo de sondeo (minutos)"

#: prefs.js:508
msgid "Range: 1-30 minutes"
msgstr "Rango: 1-30 minutos"

#: prefs.js:515
msgid "Notifications"
msgstr "Notificaciones"

#: prefs.js:516
msgid "Control how notifications behave when you interact with them."
msgstr "Controla cómo se comportan las notificaciones al interactuar con ellas."

#: prefs.js:521
msgid "Open match page on click"
msgstr "Abrir la página del partido al hacer clic"

#: prefs.js:522
msgid "Clicking a notification opens the match page in your browser."
msgstr "Al hacer clic en una notificación se abre la página del partido en tu navegador."

#: prefs.js:529
msgid "Actions"
msgstr "Acciones"

#: prefs.js:534
msgid "Force a check now"
msgstr "Forzar una comprobación"

#: prefs.js:535
msgid "Asks the background poller to refresh match data immediately."
msgstr ""
"Pide al sondeo en segundo plano que actualice los datos de los partidos de "
"inmediato."

#: prefs.js:538
msgid "Check now"
msgstr "Comprobar ahora"

#: prefs.js:555
msgid "Catalog not loaded yet"
msgstr "Catálogo aún no cargado"

#: prefs.js:556
msgid "Catalog loaded"
msgstr "Catálogo cargado"

#: prefs.js:562
msgid "Press \"Refresh now\" to load leagues and teams."
msgstr "Pulsa «Actualizar ahora» para cargar las ligas y equipos."

#: prefs.js:567 prefs.js:568
msgid "Last refreshed"
msgstr "Última actualización"

#: prefs.js:568
msgid "refresh recommended"
msgstr "se recomienda actualizar"

#: prefs.js:605
msgid "Loading catalog…"
msgstr "Cargando catálogo…"

#: prefs.js:606 prefs.js:618
msgid "Fetching leagues and teams"
msgstr "Obteniendo ligas y equipos"


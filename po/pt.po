#: prefs.js:169
msgid ""
"Leagues and teams are loaded from a public sports data source and cached "
"locally."
msgstr ""
"As ligas e equipas são carregadas de uma fonte pública de dados desportivos "
"e guardadas em cache local."

#: prefs.js:178
msgid "Refresh now"
msgstr "Atualizar agora"

#: prefs.js:235 prefs.js:251 prefs.js:340
msgid "Off"
msgstr "Desativado"

#: prefs.js:252
msgid "enabled"
msgstr "ativadas"

#: prefs.js:292
msgid "Specific teams only"
msgstr "Apenas equipas específicas"

#: prefs.js:293
msgid "Notify only for matches involving selected teams"
msgstr "Notificar apenas os jogos com equipas selecionadas"

#: prefs.js:299 prefs.js:388
msgid "Teams will appear once the catalog has loaded."
msgstr "As equipas aparecerão quando o catálogo for carregado."

#: prefs.js:343
msgid "All matches"
msgstr "Todos os jogos"

#: prefs.js:347
msgid "1 team selected"
msgstr "1 equipa selecionada"

#: prefs.js:348
msgid "teams selected"
msgstr "equipas selecionadas"

#: prefs.js:427
msgid "Events"
msgstr "Eventos"

#: prefs.js:436
msgid "Match reminder"
msgstr "Lembrete de jogo"

#: prefs.js:437
msgid "Get a heads-up before a subscribed match kicks off."
msgstr "Recebe um aviso antes de um jogo subscrito começar."

#: prefs.js:442
msgid "Remind me before kick-off"
msgstr "Lembrar antes do pontapé de saída"

#: prefs.js:456
msgid "Minutes before kick-off"
msgstr "Minutos antes do pontapé de saída"

#: prefs.js:457
msgid "Range: 5-180 minutes"
msgstr "Intervalo: 5-180 minutos"

#: prefs.js:468
msgid "Notification types"
msgstr "Tipos de notificação"

#: prefs.js:469
msgid "Choose which match events trigger a notification."
msgstr "Escolha que eventos do jogo geram uma notificação."

#: prefs.js:488
msgid "General"
msgstr "Geral"

#: prefs.js:494
msgid "Polling"
msgstr "Sondagem"

#: prefs.js:495
msgid ""
"How often to check for match updates. Lower values catch events sooner but "
"use more bandwidth."
msgstr ""
"Frequência com que se verificam atualizações dos jogos. Valores menores "
"detetam eventos mais cedo mas usam mais largura de banda."

#: prefs.js:507
msgid "Polling interval (minutes)"
msgstr "Intervalo de sondagem (minutos)"

#: prefs.js:508
msgid "Range: 1-30 minutes"
msgstr "Intervalo: 1-30 minutos"

#: prefs.js:515
msgid "Notifications"
msgstr "Notificações"

#: prefs.js:516
msgid "Control how notifications behave when you interact with them."
msgstr "Controle como as notificações se comportam quando interage com elas."

#: prefs.js:521
msgid "Open match page on click"
msgstr "Abrir a página da partida ao clicar"

#: prefs.js:522
msgid "Clicking a notification opens the match page in your browser."
msgstr "Clicar numa notificação abre a página da partida no seu navegador."

#: prefs.js:529
msgid "Actions"
msgstr "Ações"

#: prefs.js:534
msgid "Force a check now"
msgstr "Forçar uma verificação"

#: prefs.js:535
msgid "Asks the background poller to refresh match data immediately."
msgstr ""
"Pede à sondagem em segundo plano para atualizar os dados dos jogos "
"imediatamente."

#: prefs.js:538
msgid "Check now"
msgstr "Verificar agora"

#: prefs.js:555

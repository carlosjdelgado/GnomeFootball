#: prefs.js:161 prefs.js:227
msgid "Competitions"
msgstr "Compétitions"

#: prefs.js:168
msgid "Catalog"
msgstr "Catalogue"

#: prefs.js:169
msgid ""
"Leagues and teams are loaded from a public sports data source and cached "
"locally."
msgstr ""
"Les championnats et équipes sont chargés depuis une source publique de "
"données sportives et mis en cache localement."

#: prefs.js:178
msgid "Refresh now"
msgstr "Actualiser maintenant"

#: prefs.js:235 prefs.js:251 prefs.js:340
msgid "Off"
msgstr "Désactivé"

#: prefs.js:252
msgid "enabled"
msgstr "activées"

#: prefs.js:292
msgid "Specific teams only"
msgstr "Uniquement certaines équipes"

#: prefs.js:293
msgid "Notify only for matches involving selected teams"
msgstr "Notifier uniquement les matchs impliquant les équipes sélectionnées"

#: prefs.js:299 prefs.js:388
msgid "Teams will appear once the catalog has loaded."
msgstr "Les équipes apparaîtront une fois le catalogue chargé."

#: prefs.js:343
msgid "All matches"
msgstr "Tous les matchs"

#: prefs.js:347
msgid "1 team selected"
msgstr "1 équipe sélectionnée"

#: prefs.js:348
msgid "teams selected"
msgstr "équipes sélectionnées"

#: prefs.js:427
msgid "Events"
msgstr "Événements"

#: prefs.js:436
msgid "Match reminder"
msgstr "Rappel de match"

#: prefs.js:437
msgid "Get a heads-up before a subscribed match kicks off."
msgstr "Recevez une alerte avant le coup d'envoi d'un match suivi."

#: prefs.js:442
msgid "Remind me before kick-off"
msgstr "Me rappeler avant le coup d'envoi"

#: prefs.js:456
msgid "Minutes before kick-off"
msgstr "Minutes avant le coup d'envoi"

#: prefs.js:457
msgid "Range: 5-180 minutes"
msgstr "Plage : 5-180 minutes"

#: prefs.js:468
msgid "Notification types"
msgstr "Types de notification"

#: prefs.js:469
msgid "Choose which match events trigger a notification."
msgstr "Choisissez les événements du match qui déclenchent une notification."

#: prefs.js:488
msgid "General"
msgstr "Général"

#: prefs.js:494
msgid "Polling"
msgstr "Interrogation"

#: prefs.js:495
msgid ""
"How often to check for match updates. Lower values catch events sooner but "
"use more bandwidth."
msgstr ""
"Fréquence de vérification des mises à jour des matchs. Les valeurs plus "
"basses détectent les événements plus tôt mais consomment plus de bande "
"passante."

#: prefs.js:507
msgid "Polling interval (minutes)"
msgstr "Intervalle d'interrogation (minutes)"

#: prefs.js:508
msgid "Range: 1-30 minutes"
msgstr "Plage : 1-30 minutes"

#: prefs.js:515
msgid "Notifications"
msgstr "Notifications"

#: prefs.js:516
msgid "Control how notifications behave when you interact with them."
msgstr ""
"Contrôlez le comportement des notifications lorsque vous interagissez avec "
"elles."

#: prefs.js:521
msgid "Open match page on click"
msgstr "Ouvrir la page du match au clic"

#: prefs.js:522
msgid "Clicking a notification opens the match page in your browser."
msgstr ""
"Cliquer sur une notification ouvre la page du match dans votre navigateur."

#: prefs.js:529
msgid "Mute matches by default"
msgstr "Mettre les matchs en sourdine par défaut"

#: prefs.js:530
msgid "No match notifies until you un-mute it from the calendar panel."
msgstr ""
"Aucun match ne notifie tant que vous ne l’avez pas réactivé depuis le "
"panneau du calendrier."

#: prefs.js:537
msgid "Calendar panel"
msgstr "Panneau du calendrier"

#: prefs.js:538
msgid ""
"A section in the GNOME calendar (date menu) listing your subscribed matches "
"for the selected day."
msgstr "Une section dans le calendrier de GNOME (menu de la date) répertoriant les matchs suivis pour le jour sélectionné."

#: prefs.js:543
msgid "Show matches in the calendar"
msgstr "Afficher les matchs dans le calendrier"

#: prefs.js:544
msgid ""
"Browse past, current and upcoming matches by day from the top-bar clock menu."
msgstr "Parcourez les matchs passés, en cours et à venir par jour depuis le menu de l'horloge de la barre supérieure."

#: prefs.js:551
msgid "Actions"
msgstr "Actions"

#: prefs.js:556
msgid "Force a check now"
msgstr "Forcer une vérification"

#: prefs.js:557
msgid "Asks the background poller to refresh match data immediately."
msgstr ""
"Demande à l'interrogation en arrière-plan d'actualiser les données des "
"matchs immédiatement."

#: prefs.js:560
msgid "Check now"
msgstr "Vérifier maintenant"

#: prefs.js:577
msgid "Catalog not loaded yet"
msgstr "Catalogue pas encore chargé"

#: prefs.js:578
msgid "Catalog loaded"
msgstr "Catalogue chargé"

#: prefs.js:584
msgid "Press \"Refresh now\" to load leagues and teams."
msgstr ""
"Appuyez sur « Actualiser maintenant » pour charger les championnats et "
"équipes."

#: prefs.js:589 prefs.js:590
msgid "Last refreshed"
msgstr "Dernière actualisation"

#: prefs.js:590
msgid "refresh recommended"
msgstr "actualisation recommandée"

#: prefs.js:627
msgid "Loading catalog…"
msgstr "Chargement du catalogue…"

#: prefs.js:628 prefs.js:640
msgid "Fetching leagues and teams"
msgstr "Récupération des championnats et équipes"


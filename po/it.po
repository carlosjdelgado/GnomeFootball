msgid "Events"
msgstr "Eventi"

#: prefs.js:405
msgid "Notification types"
msgstr "Tipi di notifica"

#: prefs.js:406
msgid "Choose which match events trigger a notification."
msgstr "Scegli quali eventi della partita generano una notifica."

#: prefs.js:425
msgid "General"
msgstr "Generale"

#: prefs.js:431
msgid "Polling"
msgstr "Polling"

#: prefs.js:432
msgid ""
"How often to check for match updates. Lower values catch events sooner but "
"use more bandwidth."
msgstr ""
"Con quale frequenza verificare gli aggiornamenti delle partite. Valori più "
"bassi rilevano gli eventi prima ma usano più banda."

#: prefs.js:444
msgid "Polling interval (minutes)"
msgstr "Intervallo di polling (minuti)"

#: prefs.js:445
msgid "Range: 1-30 minutes"
msgstr "Intervallo: 1-30 minuti"

#: prefs.js:452
msgid "Actions"
msgstr "Azioni"

#: prefs.js:457
msgid "Force a check now"
msgstr "Forza un controllo"

#: prefs.js:458
msgid "Asks the background poller to refresh match data immediately."
msgstr ""
"Chiede al poller in background di aggiornare i dati delle partite "
"immediatamente."

#: prefs.js:461
msgid "Check now"
msgstr "Controlla ora"


msgstr "Fine del primo tempo"

#: prefs.js:63
msgid "Second half starts"
msgstr "Inizio del secondo tempo"

#: prefs.js:64 lib/notifier.js:211
msgid "Full-time"
msgstr "Fine partita"

#: prefs.js:65 lib/notifier.js:217
msgid "Extra time"
msgstr "Tempi supplementari"

#: prefs.js:66 lib/notifier.js:223
msgid "Penalty shootout"
msgstr "Calci di rigore"

#: prefs.js:161 prefs.js:227
msgid "Competitions"
msgstr "Competizioni"

#: prefs.js:168
msgid "Catalog"
msgstr "Catalogo"

#: prefs.js:169
msgid ""
"Leagues and teams are loaded from a public sports data source and cached "
"locally."
msgstr ""
"I campionati e le squadre sono caricati da una fonte pubblica di dati "
"sportivi e memorizzati nella cache locale."

#: prefs.js:178
msgid "Refresh now"
msgstr "Aggiorna ora"

#: prefs.js:235 prefs.js:251 prefs.js:340
msgid "Off"
msgstr "Disattivato"

#: prefs.js:252
msgid "enabled"
msgstr "attive"

#: prefs.js:292
msgid "Specific teams only"
msgstr "Solo squadre selezionate"

#: prefs.js:293
msgid "Notify only for matches involving selected teams"
msgstr "Notifica solo le partite che coinvolgono le squadre selezionate"

#: prefs.js:299 prefs.js:388
msgid "Teams will appear once the catalog has loaded."
msgstr "Le squadre appariranno una volta caricato il catalogo."

#: prefs.js:343
msgid "All matches"
msgstr "Tutte le partite"

#: prefs.js:347
msgid "1 team selected"
msgstr "1 squadra selezionata"

#: prefs.js:348
msgid "teams selected"
msgstr "squadre selezionate"

#: prefs.js:427
msgid "Events"
msgstr "Eventi"

#: prefs.js:436
msgid "Match reminder"
msgstr "Promemoria partita"

#: prefs.js:437
msgid "Get a heads-up before a subscribed match kicks off."
msgstr "Ricevi un avviso prima che inizi una partita seguita."

#: prefs.js:442
msgid "Remind me before kick-off"
msgstr "Avvisami prima del calcio d'inizio"

#: prefs.js:456
msgid "Minutes before kick-off"
msgstr "Minuti prima del calcio d'inizio"

#: prefs.js:457
msgid "Range: 5-180 minutes"
msgstr "Intervallo: 5-180 minuti"

#: prefs.js:468
msgid "Notification types"
msgstr "Tipi di notifica"

#: prefs.js:469
msgid "Choose which match events trigger a notification."
msgstr "Scegli quali eventi della partita generano una notifica."

#: prefs.js:488
msgid "General"
msgstr "Generale"

#: prefs.js:494
msgid "Polling"
msgstr "Polling"

#: prefs.js:495
msgid ""
"How often to check for match updates. Lower values catch events sooner but "
"use more bandwidth."
msgstr ""
"Con quale frequenza verificare gli aggiornamenti delle partite. Valori più "
"bassi rilevano gli eventi prima ma usano più banda."

#: prefs.js:507
msgid "Polling interval (minutes)"
msgstr "Intervallo di polling (minuti)"

#: prefs.js:508
msgid "Range: 1-30 minutes"
msgstr "Intervallo: 1-30 minuti"

#: prefs.js:515
msgid "Notifications"
msgstr "Notifiche"

#: prefs.js:516
msgid "Control how notifications behave when you interact with them."
msgstr "Controlla il comportamento delle notifiche quando ci interagisci."

#: prefs.js:521
msgid "Open match page on click"
msgstr "Apri la pagina della partita al clic"

#: prefs.js:522
msgid "Clicking a notification opens the match page in your browser."
msgstr ""
"Facendo clic su una notifica si apre la pagina della partita nel browser."

#: prefs.js:529
msgid "Mute matches by default"
msgstr "Silenzia le partite per impostazione predefinita"

#: prefs.js:530
msgid "No match notifies until you un-mute it from the calendar panel."
msgstr ""
"Nessuna partita invia notifiche finché non la riattivi dal pannello del "
"calendario."

#: prefs.js:537
msgid "Calendar panel"
msgstr "Pannello del calendario"

#: prefs.js:538
msgid ""
"A section in the GNOME calendar (date menu) listing your subscribed matches "
"for the selected day."
msgstr "Una sezione nel calendario di GNOME (menù della data) che elenca le partite seguite per il giorno selezionato."

#: prefs.js:543
msgid "Show matches in the calendar"
msgstr "Mostra le partite nel calendario"

#: prefs.js:544
msgid ""
"Browse past, current and upcoming matches by day from the top-bar clock menu."
msgstr "Sfoglia le partite passate, in corso e in arrivo per giorno dal menù dell'orologio nella barra superiore."

#: prefs.js:551
msgid "Actions"
msgstr "Azioni"

#: prefs.js:556
msgid "Force a check now"
msgstr "Forza un controllo"

#: prefs.js:557
msgid "Asks the background poller to refresh match data immediately."
msgstr ""
"Chiede al poller in background di aggiornare i dati delle partite "
"immediatamente."

#: prefs.js:560
msgid "Check now"
msgstr "Controlla ora"

#: prefs.js:577
msgid "Catalog not loaded yet"
msgstr "Catalogo non ancora caricato"

#: prefs.js:578
msgid "Catalog loaded"
msgstr "Catalogo caricato"

#: prefs.js:584
msgid "Press \"Refresh now\" to load leagues and teams."
msgstr "Premi «Aggiorna ora» per caricare campionati e squadre."

#: prefs.js:589 prefs.js:590
msgid "Last refreshed"
msgstr "Ultimo aggiornamento"

#: prefs.js:590
msgid "refresh recommended"
msgstr "aggiornamento consigliato"

#: prefs.js:627
msgid "Loading catalog…"
msgstr "Caricamento catalogo…"

#: prefs.js:628 prefs.js:640
msgid "Fetching leagues and teams"
msgstr "Recupero campionati e squadre"

#: lib/notifier.js:112
msgid "Home"
msgstr "Casa"

#: lib/notifier.js:113
msgid "Away"
msgstr "Trasferta"

#: lib/notifier.js:127
msgid "Upcoming match"
msgstr "Prossima partita"

#: lib/notifier.js:131
msgid "Kick-off at"
msgstr "Calcio d'inizio alle"

#: lib/notifier.js:138
msgid "Kick-off"
msgstr "Calcio d'inizio"

#: lib/notifier.js:144
msgid "GOAL"
msgstr "GOL!"

#: lib/notifier.js:154
msgid "Goal disallowed"
msgstr "Gol annullato"

#: lib/notifier.js:163
msgid "%(in)s replaces %(out)s"
msgstr "%(in)s sostituisce %(out)s"

#: lib/notifier.js:199
msgid "Half-time"
msgstr "Intervallo"

#: lib/notifier.js:205
msgid "Second half"
msgstr "Secondo tempo"

#: lib/notifier.js:229
msgid "Match update"
msgstr "Aggiornamento partita"

#: lib/notifier.js:280
msgid "Mute match"
msgstr "Silenzia partita"

#: lib/calendar-panel.js:272
msgid "Football"
msgstr "Calcio"

#: lib/calendar-panel.js:283 lib/calendar-panel.js:322
msgid "Mute all"
msgstr "Silenzia tutte"

#: lib/calendar-panel.js:321
msgid "Un-mute all"
msgstr "Riattiva tutte"

#: lib/calendar-panel.js:524
msgid "Loading…"
msgstr "Caricamento…"

#: lib/calendar-panel.js:536
msgid "No matches today"
msgstr "Nessuna partita oggi"

#: lib/calendar-panel.js:538
msgid "No matches played on this day"
msgstr "Nessuna partita giocata in questo giorno"

#: lib/calendar-panel.js:540
msgid "No matches scheduled for this day"
msgstr "Nessuna partita in programma per questo giorno"


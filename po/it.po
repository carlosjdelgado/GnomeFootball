#: prefs.js:166
msgid ""
"Leagues and teams are loaded from a public sports data source and cached "
"locally."
msgstr ""
"I campionati e le squadre sono caricati da una fonte pubblica di dati "
"sportivi e memorizzati nella cache locale."

#: prefs.js:175
msgid "Refresh now"
msgstr "Aggiorna ora"

#: prefs.js:207 prefs.js:223 prefs.js:312
msgid "Off"
msgstr "Disattivato"

#: prefs.js:224
msgid "enabled"
msgstr "attive"

#: prefs.js:264
msgid "Specific teams only"
msgstr "Solo squadre selezionate"

#: prefs.js:265
msgid "Notify only for matches involving selected teams"
msgstr "Notifica solo le partite che coinvolgono le squadre selezionate"

#: prefs.js:271 prefs.js:360
msgid "Teams will appear once the catalog has loaded."
msgstr "Le squadre appariranno una volta caricato il catalogo."

#: prefs.js:315
msgid "All matches"
msgstr "Tutte le partite"

#: prefs.js:319
msgid "1 team selected"
msgstr "1 squadra selezionata"

#: prefs.js:320
msgid "teams selected"
msgstr "squadre selezionate"

